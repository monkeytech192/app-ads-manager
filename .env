# =====================================================
# CẤU HÌNH ỨNG DỤNG ADS MANAGER
# =====================================================

# --------------------- FRONTEND (Client) ---------------------
# API URL - URL của backend server
# Local dev: http://localhost:5000/api/v1
# Production: https://your-app-production.up.railway.app/api/v1
VITE_API_URL=https://app-ads.tiemtocchu3.vn/api/v1

# Facebook App ID (BẮT BUỘC)
# Lấy từ: https://developers.facebook.com/apps
VITE_FB_APP_ID=616155604752940

# Facebook Config ID (TÙY CHỌN - chỉ cần nếu dùng Business Integration)
# Để trống nếu chỉ login cá nhân
VITE_FB_CONFIG_ID=

# --------------------- BACKEND (Server) ----------------------
# MongoDB Connection String (BẮT BUỘC)
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://admin:<db_password>@ads-manager.cfxwfhg.mongodb.net/?appName=ads-manager

# JWT Secret (BẮT BUỘC - tạo random string 32+ ký tự)
# Tạo bằng: openssl rand -base64 32
JWT_SECRET=uF9vQ3kA7L2mZP6D8sX4NwEJcH0R5YbT

# Facebook App Secret (BẮT BUỘC - chỉ cho server)
# Lấy từ: https://developers.facebook.com/apps > Settings > Basic
FACEBOOK_APP_SECRET=0b66ebf49d24af30cda7992785c111e1

# Google Gemini API (TÙY CHỌN - để trống nếu không dùng AI)
GEMINI_API_KEY=

# =====================================================
# BIẾN TỰ ĐỘNG (Không cần config)
# =====================================================
# Các biến sau được platform tự động set, KHÔNG cần thêm:
# - NODE_ENV (Railway/Vercel tự set = "production")
# - PORT (Railway/Vercel tự assign)
# - CORS_ORIGIN (Backend tự động detect từ request)
# - JWT_EXPIRE (Mặc định 7 ngày)
# - FACEBOOK_APP_ID (Backend copy từ VITE_FB_APP_ID)

# =====================================================
# HƯỚNG DẪN DEPLOY
# =====================================================
# 📖 Chi tiết: Xem file DEPLOY.md
#
# Railway/Vercel Environment Variables:
# 1. Vào Dashboard → Settings → Environment Variables
# 2. Thêm TỪNG BIẾN ở trên (5 biến BẮT BUỘC)
# 3. Save → Auto redeploy
#
# ❌ KHÔNG commit file .env lên Git (đã có trong .gitignore)
# =====================================================

